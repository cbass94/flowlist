# ════════════════════════════════════════════════════════════════════════════════
# FlowList — Environment Variables
# Copy this file to .env and fill in every value before running docker-compose.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production                         # development | production
APP_BASE_URL=https://taskflowlist.com      # public URL (must match OAuth redirect URIs)
SECRET_KEY=change-me-to-a-long-random-string-32-chars-min
SESSION_EXPIRE_HOURS=168                   # 7 days

# ── Timezone ─────────────────────────────────────────────────────────────────
# Use IANA tz name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=flowlist
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=flowlist
# Set DATABASE_URL manually (alphanumeric password recommended — avoids URL encoding issues):
DATABASE_URL=postgresql+asyncpg://flowlist:change-me-db-password@db:5432/flowlist

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
# Set REDIS_URL manually (alphanumeric password recommended):
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# ── Google OAuth — WORK account (primary login) ───────────────────────────────
# OAuth app in the Work Google Cloud project.
# Scopes needed: openid, email, profile, https://www.googleapis.com/auth/calendar
# Authorized redirect URI: https://taskflowlist.com/api/auth/callback/work
GOOGLE_WORK_CLIENT_ID=your-work-client-id.apps.googleusercontent.com
GOOGLE_WORK_CLIENT_SECRET=your-work-client-secret
GOOGLE_WORK_REDIRECT_URI=https://taskflowlist.com/api/auth/callback/work

# ── Google OAuth — PERSONAL account (secondary calendar connection) ───────────
# Scopes needed: openid, email, https://www.googleapis.com/auth/calendar
# Authorized redirect URI: https://taskflowlist.com/api/auth/callback/personal
GOOGLE_PERSONAL_CLIENT_ID=your-personal-client-id.apps.googleusercontent.com
GOOGLE_PERSONAL_CLIENT_SECRET=your-personal-client-secret
GOOGLE_PERSONAL_REDIRECT_URI=https://taskflowlist.com/api/auth/callback/personal

# ── Google Calendar IDs ───────────────────────────────────────────────────────
# Find these in Google Calendar → Settings → <calendar name> → Calendar ID
WORK_CALENDAR_ID=your-work-email@company.com
PERSONAL_CALENDAR_ID=your-personal-email@gmail.com

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Scheduling rules (all times in user's TZ, 24h format) ────────────────────
SCHEDULE_WORK_START_HOUR=8
SCHEDULE_WORK_END_HOUR=17
SCHEDULE_HARD_START_HOUR=7
SCHEDULE_HARD_END_HOUR=22
SCHEDULE_BUFFER_MINUTES=30
SCHEDULE_MAX_BLOCK_MINUTES=120
SCHEDULE_MIN_BLOCK_MINUTES=60

# ── Procrastination watchdog ──────────────────────────────────────────────────
WATCHDOG_THRESHOLD_DAYS=14
WATCHDOG_CRON=0 8 * * *

# ── CORS / allowed origins ────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://taskflowlist.com

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Two approaches — use whichever matches how you created the tunnel:
#
# A) Locally-created tunnel (cloudflared tunnel create):
#    Mount ~/.cloudflared into the container (see docker-compose.yml).
#    No token variable needed — credentials come from the mounted JSON file.
#
# B) Dashboard-created tunnel:
#    Uncomment and set the token from Zero Trust → Networks → Tunnels
#    → flowlist → Manage → Configure → Overview.
#    Update docker-compose.yml cloudflared service to use token approach.
#
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
