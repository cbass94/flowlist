# ════════════════════════════════════════════════════════════════════════════════
# FlowList — Environment Variables
# Copy this file to .env and fill in every value before running docker-compose.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development                        # development | production
APP_BASE_URL=http://localhost              # public URL (update when using tunnel)
SECRET_KEY=change-me-to-a-long-random-string-32-chars-min
SESSION_EXPIRE_HOURS=168                   # 7 days

# ── Timezone ─────────────────────────────────────────────────────────────────
# Use IANA tz name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=flowlist
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=flowlist
# Assembled automatically in docker-compose; set manually for external DB:
# DATABASE_URL=postgresql+asyncpg://flowlist:password@localhost:5432/flowlist

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
# Assembled automatically in docker-compose; set manually for external Redis:
# REDIS_URL=redis://:password@localhost:6379/0

# ── Google OAuth — WORK account (primary login) ───────────────────────────────
# OAuth app in the Work Google Cloud project.
# Scopes needed: openid, email, profile, https://www.googleapis.com/auth/calendar
GOOGLE_WORK_CLIENT_ID=your-work-client-id.apps.googleusercontent.com
GOOGLE_WORK_CLIENT_SECRET=your-work-client-secret
GOOGLE_WORK_REDIRECT_URI=${APP_BASE_URL}/api/auth/callback/work

# ── Google OAuth — PERSONAL account (secondary calendar connection) ───────────
# Can be a second OAuth app OR the same app with a different redirect URI.
# Scopes needed: openid, email, profile, https://www.googleapis.com/auth/calendar
GOOGLE_PERSONAL_CLIENT_ID=your-personal-client-id.apps.googleusercontent.com
GOOGLE_PERSONAL_CLIENT_SECRET=your-personal-client-secret
GOOGLE_PERSONAL_REDIRECT_URI=${APP_BASE_URL}/api/auth/callback/personal

# ── Google Calendar IDs ───────────────────────────────────────────────────────
# Find these in Google Calendar → Settings → <calendar name> → Calendar ID
WORK_CALENDAR_ID=your-work-email@company.com
PERSONAL_CALENDAR_ID=your-personal-email@gmail.com

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514   # model used for task parsing & estimation

# ── Scheduling rules (all times in user's TZ, 24h format) ────────────────────
SCHEDULE_WORK_START_HOUR=8                 # Work tasks: earliest start
SCHEDULE_WORK_END_HOUR=17                  # Work tasks: latest end
SCHEDULE_HARD_START_HOUR=7                 # Absolute earliest (any task)
SCHEDULE_HARD_END_HOUR=22                  # Absolute latest (any task)
SCHEDULE_BUFFER_MINUTES=30                 # Required free time BEFORE each auto-block
SCHEDULE_MAX_BLOCK_MINUTES=120             # Maximum single session length
SCHEDULE_MIN_BLOCK_MINUTES=60             # Minimum split-session length

# ── Procrastination watchdog ──────────────────────────────────────────────────
WATCHDOG_THRESHOLD_DAYS=14                 # Days before procrastination flag is set
WATCHDOG_CRON=0 8 * * *                    # Daily at 8am (cron syntax, in TZ above)

# ── CORS / allowed origins ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:80
